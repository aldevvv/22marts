              "func_response": "{\n  \"status\": \"OK\",\n  \"message\": \"  1→\\\"use client\\\";\\n  2→\\n  3→import { useState, useEffect } from \\\"react\\\";\\n  4→import { Search, Plus, MoreHorizontal, Package, Pencil, Trash2, X, Loader2 } from \\\"lucide-react\\\";\\n  5→import { toast } from \\\"sonner\\\";\\n  6→import { Button } from \\\"@/components/ui/button\\\";\\n  7→import { getCategories, createCategory, updateCategory, deleteCategory, Category } from \\\"@/lib/api\\\";\\n  8→\\n  9→export default function KelolaKategoriPage() {\\n 10→  const [categories, setCategories] = useState<Category[]>([]);\\n 11→  const [loading, setLoading] = useState(true);\\n 12→  const [search, setSearch] = useState(\\\"\\\");\\n 13→  \\n 14→  // Modal state\\n 15→  const [showModal, setShowModal] = useState(false);\\n 16→  const [editingCategory, setEditingCategory] = useState<Category | null>(null);\\n 17→  const [formData, setFormData] = useState({ name: \\\"\\\", icon: \\\"\\\", isActive: true });\\n 18→  const [submitting, setSubmitting] = useState(false);\\n 19→  \\n 20→  // Delete state\\n 21→  const [deleteId, setDeleteId] = useState<string | null>(null);\\n 22→  const [deleting, setDeleting] = useState(false);\\n 23→\\n 24→  useEffect(() => {\\n 25→    loadCategories();\\n 26→  }, []);\\n 27→\\n 28→  async function loadCategories() {\\n 29→    setLoading(true);\\n 30→    const result = await getCategories();\\n 31→    if (result.data) {\\n 32→      setCategories(result.data);\\n 33→    } else {\\n 34→      toast.error(result.error);\\n 35→    }\\n 36→    setLoading(false);\\n 37→  }\\n 38→\\n 39→  function openCreateModal() {\\n 40→    setEditingCategory(null);\\n 41→    setFormData({ name: \\\"\\\", icon: \\\"\\\", isActive: true });\\n 42→    setShowModal(true);\\n 43→  }\\n 44→\\n 45→  function openEditModal(category: Category) {\\n 46→    setEditingCategory(category);\\n 47→    setFormData({\\n 48→      name: category.name,\\n 49→      icon: category.icon || \\\"\\\",\\n 50→      isActive: category.isActive,\\n 51→    });\\n 52→    setShowModal(true);\\n 53→  }\\n 54→\\n 55→  async function handleSubmit(e: React.FormEvent) {\\n 56→    e.preventDefault();\\n 57→    setSubmitting(true);\\n 58→\\n 59→    const data = {\\n 60→      name: formData.name,\\n 61→      icon: formData.icon || undefined,\\n 62→      isActive: formData.isActive,\\n 63→    };\\n 64→\\n 65→    if (editingCategory) {\\n 66→      const result = await updateCategory(editingCategory.id, data);\\n 67→      if (result.data) {\\n 68→        toast.success(\\\"Kategori berhasil diupdate\\\");\\n 69→        loadCategories();\\n 70→        setShowModal(false);\\n 71→      } else {\\n 72→        toast.error(result.error);\\n 73→      }\\n 74→    } else {\\n 75→      const result = await createCategory(data);\\n 76→      if (result.data) {\\n 77→        toast.success(\\\"Kategori berhasil ditambahkan\\\");\\n 78→        loadCategories();\\n 79→        setShowModal(false);\\n 80→      } else {\\n 81→        toast.error(result.error);\\n 82→      }\\n 83→    }\\n 84→\\n 85→    setSubmitting(false);\\n 86→  }\\n 87→\\n 88→  async function handleDelete() {\\n 89→    if (!deleteId) return;\\n 90→    setDeleting(true);\\n 91→\\n 92→    const result = await deleteCategory(deleteId);\\n 93→    if (!result.error) {\\n 94→      toast.success(\\\"Kategori berhasil dihapus\\\");\\n 95→      loadCategories();\\n 96→      setDeleteId(null);\\n 97→    } else {\\n 98→      toast.error(result.error);\\n 99→    }\\n100→\\n101→    setDeleting(false);\\n102→  }\\n103→\\n104→  const filteredCategories = categories.filter((cat) =>\\n105→    cat.name.toLowerCase().includes(search.toLowerCase())\\n106→  );\\n107→\\n108→  return (\\n109→    <div className=\\\"space-y-4\\\">\\n110→      <div className=\\\"flex items-center justify-between\\\">\\n111→        <div>\\n112→          <h1 className=\\\"text-lg font-semibold\\\">Kelola Kategori</h1>\\n113→          <p className=\\\"text-sm text-zinc-500\\\">{categories.length} kategori tersedia</p>\\n114→        </div>\\n115→        <Button size=\\\"sm\\\" className=\\\"h-8 gap-1.5 bg-zinc-900 text-xs\\\" onClick={openCreateModal}>\\n116→          <Plus className=\\\"h-3.5 w-3.5\\\" /> Tambah Kategori\\n117→        </Button>\\n118→      </div>\\n119→\\n120→      {/* Search */}\\n121→      <div className=\\\"flex flex-wrap items-center gap-2\\\">\\n122→        <div className=\\\"relative flex-1 min-w-[200px] max-w-xs\\\">\\n123→          <Search className=\\\"absolute left-2.5 top-1/2 h-4 w-4 -translate-y-1/2 text-zinc-400\\\" />\\n124→          <input\\n125→            type=\\\"text\\\"\\n126→            placeholder=\\\"Cari kategori...\\\"\\n127→            value={search}\\n128→            onChange={(e) => setSearch(e.target.value)}\\n129→            className=\\\"h-8 w-full rounded-md border border-zinc-200 bg-white pl-8 pr-3 text-sm placeholder:text-zinc-400 focus:border-zinc-900 focus:outline-none focus:ring-1 focus:ring-zinc-900\\\"\\n130→          />\\n131→        </div>\\n132→      </div>\\n133→\\n134→      {/* Grid */}\\n135→      {loading ? (\\n136→        <div className=\\\"flex items-center justify-center py-12\\\">\\n137→          <Loader2 className=\\\"h-6 w-6 animate-spin text-zinc-400\\\" />\\n138→        </div>\\n139→      ) : (\\n140→        <div className=\\\"grid gap-3 sm:grid-cols-2 lg:grid-cols-4\\\">\\n141→          {filteredCategories.map((category) => (\\n142→            <div\\n143→              key={category.id}\\n144→              className=\\\"group relative rounded-lg border border-zinc-200 bg-white p-4 hover:border-zinc-300 hover:shadow-sm\\\"\\n145→            >\\n146→              {/* Actions Dropdown */}\\n147→              <div className=\\\"absolute right-2 top-2 flex gap-1 opacity-0 group-hover:opacity-100\\\">\\n148→                <button\\n149→                  onClick={() => openEditModal(category)}\\n150→                  className=\\\"rounded-md p-1.5 hover:bg-zinc-100\\\"\\n151→                >\\n152→                  <Pencil className=\\\"h-3.5 w-3.5 text-zinc-500\\\" />\\n153→                </button>\\n154→                <button\\n155→                  onClick={() => setDeleteId(category.id)}\\n156→                  className=\\\"rounded-md p-1.5 hover:bg-red-50\\\"\\n157→                >\\n158→                  <Trash2 className=\\\"h-3.5 w-3.5 text-red-500\\\" />\\n159→                </button>\\n160→              </div>\\n161→\\n162→              <div className=\\\"mb-3 flex h-12 w-12 items-center justify-center rounded-lg bg-zinc-100 text-2xl\\\">\\n163→                {category.icon || \\\"📦\\\"}\\n164→              </div>\\n165→\\n166→              <h3 className=\\\"font-medium\\\">{category.name}</h3>\\n167→              <p className=\\\"text-xs text-zinc-500\\\">/{category.slug}</p>\\n168→\\n169→              <div className=\\\"mt-3 flex items-center justify-between\\\">\\n170→                <div className=\\\"flex items-center gap-1 text-xs text-zinc-500\\\">\\n171→                  <Package className=\\\"h-3.5 w-3.5\\\" />\\n172→                  {category._count?.products || 0} produk\\n173→                </div>\\n174→                <span\\n175→                  className={`rounded-full px-2 py-0.5 text-[10px] font-medium ${\\n176→                    category.isActive ? \\\"bg-green-100 text-green-700\\\" : \\\"bg-red-100 text-red-700\\\"\\n177→                  }`}\\n178→                >\\n179→                  {category.isActive ? \\\"Aktif\\\" : \\\"Nonaktif\\\"}\\n180→                </span>\\n181→              </div>\\n182→            </div>\\n183→          ))}\\n184→\\n185→          {/* Add New Card */}\\n186→          <button\\n187→            onClick={openCreateModal}\\n188→            className=\\\"flex flex-col items-center justify-center rounded-lg border-2 border-dashed border-zinc-200 bg-zinc-50 p-4 text-zinc-400 hover:border-zinc-300 hover:text-zinc-600\\\"\\n189→          >\\n190→            <Plus className=\\\"h-8 w-8\\\" />\\n191→            <span className=\\\"mt-2 text-sm font-medium\\\">Tambah Kategori</span>\\n192→          </button>\\n193→        </div>\\n194→      )}\\n195→\\n196→      {/* Create/Edit Modal */}\\n197→      {showModal && (\\n198→        <div className=\\\"fixed inset-0 z-50 flex items-center justify-center bg-black/50\\\">\\n199→          <div className=\\\"w-full max-w-md rounded-xl bg-white p-6\\\">\\n200→            <div className=\\\"flex items-center justify-between mb-4\\\">\\n201→              <h2 className=\\\"text-lg font-semibold\\\">\\n202→                {editingCategory ? \\\"Edit Kategori\\\" : \\\"Tambah Kategori\\\"}\\n203→              </h2>\\n204→              <button onClick={() => setShowModal(false)} className=\\\"p-1 hover:bg-zinc-100 rounded\\\">\\n205→                <X className=\\\"h-5 w-5\\\" />\\n206→              </button>\\n207→            </div>\\n208→\\n209→            <form onSubmit={handleSubmit} className=\\\"space-y-4\\\">\\n210→              <div>\\n211→                <label className=\\\"block text-sm font-medium mb-1\\\">Nama Kategori</label>\\n212→                <input\\n213→                  type=\\\"text\\\"\\n214→                  required\\n215→                  value={formData.name}\\n216→                  onChange={(e) => setFormData({ ...formData, name: e.target.value })}\\n217→                  className=\\\"h-9 w-full rounded-md border border-zinc-200 px-3 text-sm focus:border-zinc-900 focus:outline-none focus:ring-1 focus:ring-zinc-900\\\"\\n218→                  placeholder=\\\"Contoh: Sayur & Buah\\\"\\n219→                />\\n220→              </div>\\n221→\\n222→              <div>\\n223→                <label className=\\\"block text-sm font-medium mb-1\\\">Icon (Emoji)</label>\\n224→                <input\\n225→                  type=\\\"text\\\"\\n226→                  value={formData.icon}\\n227→                  onChange={(e) => setFormData({ ...formData, icon: e.target.value })}\\n228→                  className=\\\"h-9 w-full rounded-md border border-zinc-200 px-3 text-sm focus:border-zinc-900 focus:outline-none focus:ring-1 focus:ring-zinc-900\\\"\\n229→                  placeholder=\\\"Contoh: 🥬\\\"\\n230→                />\\n231→              </div>\\n232→\\n233→              <div className=\\\"flex items-center gap-2\\\">\\n234→                <input\\n235→                  type=\\\"checkbox\\\"\\n236→                  id=\\\"isActive\\\"\\n237→                  checked={formData.isActive}\\n238→                  onChange={(e) => setFormData({ ...formData, isActive: e.target.checked })}\\n239→                  className=\\\"h-4 w-4 rounded\\\"\\n240→                />\\n241→                <label htmlFor=\\\"isActive\\\" className=\\\"text-sm\\\">Aktif</label>\\n242→              </div>\\n243→\\n244→              <div className=\\\"flex gap-2 pt-2\\\">\\n245→                <Button\\n246→                  type=\\\"button\\\"\\n247→                  variant=\\\"outline\\\"\\n248→                  className=\\\"flex-1 h-9\\\"\\n249→                  onClick={() => setShowModal(false)}\\n250→                >\\n251→                  Batal\\n252→                </Button>\\n253→                <Button type=\\\"submit\\\" className=\\\"flex-1 h-9 bg-zinc-900\\\" disabled={submitting}>\\n254→                  {submitting ? <Loader2 className=\\\"h-4 w-4 animate-spin\\\" /> : \\\"Simpan\\\"}\\n255→                </Button>\\n256→              </div>\\n257→            </form>\\n258→          </div>\\n259→        </div>\\n260→      )}\\n261→\\n262→      {/* Delete Confirmation Modal */}\\n263→      {deleteId && (\\n264→        <div className=\\\"fixed inset-0 z-50 flex items-center justify-center bg-black/50\\\">\\n265→          <div className=\\\"w-full max-w-sm rounded-xl bg-white p-6\\\">\\n266→            <h2 className=\\\"text-lg font-semibold\\\">Hapus Kategori?</h2>\\n267→            <p className=\\\"mt-2 text-sm text-zinc-500\\\">\\n268→              Kategori yang dihapus tidak dapat dikembalikan. Pastikan tidak ada produk yang menggunakan kategori ini.\\n269→            </p>\\n270→            <div className=\\\"flex gap-2 mt-4\\\">\\n271→              <Button\\n272→                variant=\\\"outline\\\"\\n273→                className=\\\"flex-1 h-9\\\"\\n274→                onClick={() => setDeleteId(null)}\\n275→              >\\n276→                Batal\\n277→              </Button>\\n278→              <Button\\n279→                className=\\\"flex-1 h-9 bg-red-600 hover:bg-red-700\\\"\\n280→                onClick={handleDelete}\\n281→                disabled={deleting}\\n282→              >\\n283→                {deleting ? <Loader2 className=\\\"h-4 w-4 animate-spin\\\" /> : \\\"Hapus\\\"}\\n284→              </Button>\\n285→            </div>\\n286→          </div>\\n287→        </div>\\n288→      )}\\n289→    </div>\\n290→  );\\n291→}\\n292→\",\n  \"time\": \"2026-04-17 02:36:02 PM UTC+0000\"\n}"
