              "func_response": "{\n  \"status\": \"OK\",\n  \"message\": \"  1→const API_URL = process.env.NEXT_PUBLIC_API_URL || 'http://localhost:4000/api';\\n  2→\\n  3→interface ApiResponse<T = unknown> {\\n  4→  data?: T;\\n  5→  error?: string;\\n  6→}\\n  7→\\n  8→interface AuthResponse {\\n  9→  message: string;\\n 10→  user: {\\n 11→    id: string;\\n 12→    name: string;\\n 13→    email: string;\\n 14→    role: string;\\n 15→  };\\n 16→  token: string;\\n 17→}\\n 18→\\n 19→export interface Category {\\n 20→  id: string;\\n 21→  name: string;\\n 22→  slug: string;\\n 23→  icon: string | null;\\n 24→  isActive: boolean;\\n 25→  createdAt: string;\\n 26→  updatedAt: string;\\n 27→  _count?: { products: number };\\n 28→}\\n 29→\\n 30→export interface Product {\\n 31→  id: string;\\n 32→  name: string;\\n 33→  slug: string;\\n 34→  description: string | null;\\n 35→  price: number;\\n 36→  stock: number;\\n 37→  thumbnail: string | null;\\n 38→  isActive: boolean;\\n 39→  categoryId: string;\\n 40→  category?: Category;\\n 41→  createdAt: string;\\n 42→  updatedAt: string;\\n 43→}\\n 44→\\n 45→// Auth\\n 46→export async function register(data: {\\n 47→  name: string;\\n 48→  email: string;\\n 49→  password: string;\\n 50→}): Promise<ApiResponse<AuthResponse>> {\\n 51→  try {\\n 52→    const res = await fetch(`${API_URL}/auth/register`, {\\n 53→      method: 'POST',\\n 54→      headers: { 'Content-Type': 'application/json' },\\n 55→      body: JSON.stringify(data),\\n 56→    });\\n 57→\\n 58→    const json = await res.json();\\n 59→\\n 60→    if (!res.ok) {\\n 61→      return { error: json.message || 'Registrasi gagal' };\\n 62→    }\\n 63→\\n 64→    return { data: json };\\n 65→  } catch {\\n 66→    return { error: 'Terjadi kesalahan. Silakan coba lagi.' };\\n 67→  }\\n 68→}\\n 69→\\n 70→export async function login(data: {\\n 71→  email: string;\\n 72→  password: string;\\n 73→}): Promise<ApiResponse<AuthResponse>> {\\n 74→  try {\\n 75→    const res = await fetch(`${API_URL}/auth/login`, {\\n 76→      method: 'POST',\\n 77→      headers: { 'Content-Type': 'application/json' },\\n 78→      body: JSON.stringify(data),\\n 79→    });\\n 80→\\n 81→    const json = await res.json();\\n 82→\\n 83→    if (!res.ok) {\\n 84→      return { error: json.message || 'Login gagal' };\\n 85→    }\\n 86→\\n 87→    return { data: json };\\n 88→  } catch {\\n 89→    return { error: 'Terjadi kesalahan. Silakan coba lagi.' };\\n 90→  }\\n 91→}\\n 92→\\n 93→// Categories\\n 94→export async function getCategories(): Promise<ApiResponse<Category[]>> {\\n 95→  try {\\n 96→    const res = await fetch(`${API_URL}/categories`);\\n 97→    const json = await res.json();\\n 98→    if (!res.ok) return { error: json.message || 'Gagal memuat kategori' };\\n 99→    return { data: json };\\n100→  } catch {\\n101→    return { error: 'Terjadi kesalahan' };\\n102→  }\\n103→}\\n104→\\n105→export async function createCategory(data: {\\n106→  name: string;\\n107→  icon?: string;\\n108→  isActive?: boolean;\\n109→}): Promise<ApiResponse<Category>> {\\n110→  try {\\n111→    const res = await fetch(`${API_URL}/categories`, {\\n112→      method: 'POST',\\n113→      headers: { 'Content-Type': 'application/json' },\\n114→      body: JSON.stringify(data),\\n115→    });\\n116→    const json = await res.json();\\n117→    if (!res.ok) return { error: json.message || 'Gagal membuat kategori' };\\n118→    return { data: json };\\n119→  } catch {\\n120→    return { error: 'Terjadi kesalahan' };\\n121→  }\\n122→}\\n123→\\n124→export async function updateCategory(\\n125→  id: string,\\n126→  data: { name?: string; icon?: string; isActive?: boolean }\\n127→): Promise<ApiResponse<Category>> {\\n128→  try {\\n129→    const res = await fetch(`${API_URL}/categories/${id}`, {\\n130→      method: 'PUT',\\n131→      headers: { 'Content-Type': 'application/json' },\\n132→      body: JSON.stringify(data),\\n133→    });\\n134→    const json = await res.json();\\n135→    if (!res.ok) return { error: json.message || 'Gagal mengupdate kategori' };\\n136→    return { data: json };\\n137→  } catch {\\n138→    return { error: 'Terjadi kesalahan' };\\n139→  }\\n140→}\\n141→\\n142→export async function deleteCategory(id: string): Promise<ApiResponse<void>> {\\n143→  try {\\n144→    const res = await fetch(`${API_URL}/categories/${id}`, {\\n145→      method: 'DELETE',\\n146→    });\\n147→    if (!res.ok) {\\n148→      const json = await res.json();\\n149→      return { error: json.message || 'Gagal menghapus kategori' };\\n150→    }\\n151→    return { data: undefined };\\n152→  } catch {\\n153→    return { error: 'Terjadi kesalahan' };\\n154→  }\\n155→}\\n156→\\n157→// Products\\n158→export async function getProducts(categoryId?: string): Promise<ApiResponse<Product[]>> {\\n159→  try {\\n160→    const url = categoryId\\n161→      ? `${API_URL}/products?categoryId=${categoryId}`\\n162→      : `${API_URL}/products`;\\n163→    const res = await fetch(url);\\n164→    const json = await res.json();\\n165→    if (!res.ok) return { error: json.message || 'Gagal memuat produk' };\\n166→    return { data: json };\\n167→  } catch {\\n168→    return { error: 'Terjadi kesalahan' };\\n169→  }\\n170→}\\n171→\\n172→export async function createProduct(data: FormData): Promise<ApiResponse<Product>> {\\n173→  try {\\n174→    const res = await fetch(`${API_URL}/products`, {\\n175→      method: 'POST',\\n176→      body: data,\\n177→    });\\n178→    const json = await res.json();\\n179→    if (!res.ok) return { error: json.message || 'Gagal membuat produk' };\\n180→    return { data: json };\\n181→  } catch {\\n182→    return { error: 'Terjadi kesalahan' };\\n183→  }\\n184→}\\n185→\\n186→export async function updateProduct(\\n187→  id: string,\\n188→  data: FormData\\n189→): Promise<ApiResponse<Product>> {\\n190→  try {\\n191→    const res = await fetch(`${API_URL}/products/${id}`, {\\n192→      method: 'PUT',\\n193→      body: data,\\n194→    });\\n195→    const json = await res.json();\\n196→    if (!res.ok) return { error: json.message || 'Gagal mengupdate produk' };\\n197→    return { data: json };\\n198→  } catch {\\n199→    return { error: 'Terjadi kesalahan' };\\n200→  }\\n201→}\\n202→\\n203→export async function deleteProduct(id: string): Promise<ApiResponse<void>> {\\n204→  try {\\n205→    const res = await fetch(`${API_URL}/products/${id}`, {\\n206→      method: 'DELETE',\\n207→    });\\n208→    if (!res.ok) {\\n209→      const json = await res.json();\\n210→      return { error: json.message || 'Gagal menghapus produk' };\\n211→    }\\n212→    return { data: undefined };\\n213→  } catch {\\n214→    return { error: 'Terjadi kesalahan' };\\n215→  }\\n216→}\\n217→\",\n  \"time\": \"2026-04-17 03:48:44 PM UTC+0000\"\n}"
