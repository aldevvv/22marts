oard\\\", icon: LayoutDashboard },\\n 62→      { href: \\\"/admin/pesanan\\\", label: \\\"Kelola Pesanan\\\", icon: ShoppingCart },\\n 63→    ],\\n 64→  },\\n 65→  {\\n 66→    label: \\\"Katalog\\\",\\n 67→    items: [\\n 68→      { href: \\\"/admin/produk\\\", label: \\\"Kelola Produk\\\", icon: Package },\\n 69→      { href: \\\"/admin/kategori\\\", label: \\\"Kelola Kategori\\\", icon: Tag },\\n 70→    ],\\n 71→  },\\n 72→  {\\n 73→    label: \\\"Manajemen\\\",\\n 74→    items: [\\n 75→      { href: \\\"/admin/pengguna\\\", label: \\\"Kelola User\\\", icon: Users },\\n 76→      { href: \\\"/admin/promo\\\", label: \\\"Kelola Promo\\\", icon: CreditCard },\\n 77→      { href: \\\"/admin/ulasan\\\", label: \\\"Kelola Ulasan\\\", icon: MessageSquare },\\n 78→    ],\\n 79→  },\\n 80→  {\\n 81→    label: \\\"Laporan\\\",\\n 82→    items: [\\n 83→      { href: \\\"/admin/laporan\\\", label: \\\"Statistik\\\", icon: BarChart3 },\\n 84→      { href: \\\"/admin/pengaturan\\\", label: \\\"Pengaturan\\\", icon: Settings },\\n 85→    ],\\n 86→  },\\n 87→];\\n 88→\\n 89→interface User {\\n 90→  id: string;\\n 91→  name: string;\\n 92→  email: string;\\n 93→  role: string;\\n 94→}\\n 95→\\n 96→export default function ProtectedLayout({ children }: { children: React.ReactNode }) {\\n 97→  const router = useRouter();\\n 98→  const pathname = usePathname();\\n 99→  const [user, setUser] = useState<User | null>(null);\\n100→  const [dropdownOpen, setDropdownOpen] = useState(false);\\n101→  const [sidebarOpen, setSidebarOpen] = useState(false);\\n102→\\n103→  const isAdmin = user?.role === \\\"ADMIN\\\";\\n104→  const sidebarSections = isAdmin ? adminLinks : userLinks;\\n105→\\n106→  useEffect(() => {\\n107→    const storedUser = localStorage.getItem(\\\"user\\\");\\n108→    const token = localStorage.getItem(\\\"token\\\");\\n109→\\n110→    if (!token || !storedUser) {\\n111→      router.push(\\\"/masuk\\\");\\n112→      return;\\n113→    }\\n114→\\n115→    setUser(JSON.parse(storedUser));\\n116→  }, [router]);\\n117→\\n118→  function handleLogout() {\\n119→    localStorage.removeItem(\\\"token\\\");\\n120→    localStorage.removeItem(\\\"user\\\");\\n121→    toast.success(\\\"Berhasil keluar\\\");\\n122→    router.push(\\\"/masuk\\\");\\n123→  }\\n124→\\n125→  if (!user) {\\n126→    return (\\n127→      <div className=\\\"flex min-h-screen items-center justify-center\\\">\\n128→        <div className=\\\"h-6 w-6 animate-spin rounded-full border-2 border-zinc-200 border-t-zinc-900\\\" />\\n129→      </div>\\n130→    );\\n131→  }\\n132→\\n133→  return (\\n134→    <div className=\\\"flex min-h-screen bg-zinc-50\\\">\\n135→      {/* Sidebar - Desktop */}\\n136→      <aside className=\\\"hidden w-56 flex-col border-r border-zinc-200 bg-white lg:flex\\\">\\n137→        {/* Search */}\\n138→        <div className=\\\"border-b border-zinc-200 p-3\\\">\\n139→          <button className=\\\"flex h-9 w-full items-center gap-2 rounded-lg border border-zinc-200 bg-zinc-50 px-3 text-sm text-zinc-500 hover:bg-zinc-100\\\">\\n140→            <Search className=\\\"h-4 w-4\\\" />\\n141→            <span className=\\\"flex-1 text-left\\\">Cari...</span>\\n142→            <kbd className=\\\"hidden rounded bg-zinc-200 px-1.5 py-0.5 text-[10px] font-medium text-zinc-500 sm:inline\\\">\\n143→              ⌘F\\n144→            </kbd>\\n145→          </button>\\n146→        </div>\\n147→\\n148→        {/* Navigation */}\\n149→        <nav className=\\\"flex-1 overflow-y-auto p-3\\\">\\n150→          {sidebarSections.map((section) => (\\n151→            <div key={section.label} className=\\\"mb-4\\\">\\n152→              <p className=\\\"mb-1 px-2 text-[10px] font-semibold uppercase tracking-wider text-zinc-400\\\">\\n153→                {section.label}\\n154→              </p>\\n155→              <div className=\\\"space-y-0.5\\\">\\n156→                {section.items.map((link) => {\\n157→                  const isActive = pathname === link.href;\\n158→             