              "func_response": "{\n  \"status\": \"OK\",\n  \"message\": \" 1→import { Injectable, OnModuleInit, OnModuleDestroy } from '@nestjs/common';\\n 2→import { PrismaClient } from '@prisma/client';\\n 3→import { PrismaPg } from '@prisma/adapter-pg';\\n 4→import pg from 'pg';\\n 5→\\n 6→@Injectable()\\n 7→export class PrismaService implements OnModuleInit, OnModuleDestroy {\\n 8→  private prisma: PrismaClient;\\n 9→\\n10→  constructor() {\\n11→    const pool = new pg.Pool({\\n12→      connectionString: process.env.DATABASE_URL,\\n13→    });\\n14→    const adapter = new PrismaPg(pool);\\n15→    this.prisma = new PrismaClient({ adapter });\\n16→  }\\n17→\\n18→  async onModuleInit() {\\n19→    await this.prisma.$connect();\\n20→  }\\n21→\\n22→  async onModuleDestroy() {\\n23→    await this.prisma.$disconnect();\\n24→  }\\n25→\\n26→  get user() {\\n27→    return this.prisma.user;\\n28→  }\\n29→}\\n30→\",\n  \"time\": \"2026-04-17 02:04:12 PM UTC+0000\"\n}"
