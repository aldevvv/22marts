              "tool_call_id": "toolu_01QyMAinpVYD7pNYwMX46cRZ",
              "status": "success",
              "stdout": null,
              "stderr": null,
              "func_response": "{\n  \"status\": \"OK\",\n  \"message\": \"  1→\\\"use client\\\";\\n  2→\\n  3→import { useState, useEffect, useRef } from \\\"react\\\";\\n  4→import {\\n  5→  Search,\\n  6→  Plus,\\n  7→  Pencil,\\n  8→  Trash2,\\n  9→  X,\\n 10→  Loader2,\\n 11→  Upload,\\n 12→  ImageIcon,\\n 13→  Package,\\n 14→} from \\\"lucide-react\\\";\\n 15→import { toast } from \\\"sonner\\\";\\n 16→import { Button } from \\\"@/components/ui/button\\\";\\n 17→import {\\n 18→  getProducts,\\n 19→  getCategories,\\n 20→  createProduct,\\n 21→  updateProduct,\\n 22→  deleteProduct,\\n 23→  Product,\\n 24→  Category,\\n 25→} from \\\"@/lib/api\\\";\\n 26→\\n 27→export default function KelolaProdukPage() {\\n 28→  const [products, setProducts] = useState<Product[]>([]);\\n 29→  const [categories, setCategories] = useState<Category[]>([]);\\n 30→  const [loading, setLoading] = useState(true);\\n 31→  const [search, setSearch] = useState(\\\"\\\");\\n 32→  const [filterCategory, setFilterCategory] = useState(\\\"\\\");\\n 33→  const [filterStatus, setFilterStatus] = useState(\\\"\\\");\\n 34→\\n 35→  const [showModal, setShowModal] = useState(false);\\n 36→  const [editingProduct, setEditingProduct] = useState<Product | null>(null);\\n 37→  const [formData, setFormData] = useState({\\n 38→    name: \\\"\\\",\\n 39→    description: \\\"\\\",\\n 40→    price: \\\"\\\",\\n 41→    stock: \\\"\\\",\\n 42→    categoryId: \\\"\\\",\\n 43→    isActive: true,\\n 44→  });\\n 45→  const [thumbnailFile, setThumbnailFile] = useState<File | null>(null);\\n 46→  const [thumbnailPreview, setThumbnailPreview] = useState<string | null>(null);\\n 47→  const [submitting, setSubmitting] = useState(false);\\n 48→  const fileInputRef = useRef<HTMLInputElement>(null);\\n 49→\\n 50→  const [deleteId, setDeleteId] = useState<string | null>(null);\\n 51→  const [deleting, setDeleting] = useState(false);\\n 52→\\n 53→  useEffect(() => {\\n 54→    loadData();\\n 55→  }, []);\\n 56→\\n 57→  async function loadData() {\\n 58→    setLoading(true);\\n 59→    const [productsRes, categoriesRes] = await Promise.all([\\n 60→      getProducts(),\\n 61→      getCategories(),\\n 62→    ]);\\n 63→    if (productsRes.data) setProducts(productsRes.data);\\n 64→    if (categoriesRes.data) setCategories(categoriesRes.data);\\n 65→    setLoading(false);\\n 66→  }\\n 67→\\n 68→  function openCreateModal() {\\n 69→    setEditingProduct(null);\\n 70→    setFormData({\\n 71→      name: \\\"\\\",\\n 72→      description: \\\"\\\",\\n 73→      price: \\\"\\\",\\n 74→      stock: \\\"\\\",\\n 75→      categoryId: categories[0]?.id || \\\"\\\",\\n 76→      isActive: true,\\n 77→    });\\n 78→    setThumbnailFile(null);\\n 79→    setThumbnailPreview(null);\\n 80→    setShowModal(true);\\n 81→  }\\n 82→\\n 83→  function openEditModal(product: Product) {\\n 84→    setEditingProduct(product);\\n 85→    setFormData({\\n 86→      name: product.name,\\n 87→      description: product.description || \\\"\\\",\\n 88→      price: product.price.toString(),\\n 89→      stock: product.stock.toString(),\\n 90→      categoryId: product.categoryId,\\n 91→      isActive: product.isActive,\\n 92→    });\\n 93→    setThumbnailFile(null);\\n 94→    setThumbnailPreview(product.thumbnail);\\n 95→    setShowModal(true);\\n 96→  }\\n 97→\\n 98→  function handleFileChange(e: React.ChangeEvent<HTMLInputElement>) {\\n 99→    const file = e.target.files?.[0];\\n100→    if (file) {\\n101→      setThumbnailFile(file);\\n102→      setThumbnailPreview(URL.createObjectURL(file));\\n103→    }\\n104→  }\\n105→\\n106→  async function handleSubmit(e: React.FormEvent) {\\n107→    e.preventDefault();\\n108→    setSubmitting(true);\\n109→\\n110→    const data = new FormData();\\n111→    data.append(\\\"name\\\", formData.name);\\n112→    data.append(\\\"description\\\", formData.description);\\n113→    data.append(\\\"price\\\", formData.price);\\n114→    data.append(\\\"stock\\\", formData.stock);\\n115→    data.append(\\\"categoryId\\\", formData.categoryId);\\n116→    data.append(\\\"isActive\\\", formData.isActive.toString());\\n117→\\n118→    if (thumbnailFile) {\\n119→      data.append(\\\"thumbnail\\\", thumbnailFile);\\n120→    }\\n121→\\n122→    if (editingProduct) {\\n123→      const result = await updateProduct(editingProduct.id, data);\\n124→      if (result.data) {\\n125→        toast.success(\\\"Produk berhasil diupdate\\\");\\n126→        loadData();\\n127→        setShowModal(false);\\n128→      } else {\\n129→        toast.error(result.error);\\n130→      }\\n131→    } else {\\n132→      const result = await createProduct(data);\\n133→      if (result.data) {\\n134→        toast.success(\\\"Produk berhasil ditambahkan\\\");\\n135→        loadData();\\n136→        setShowModal(false);\\n137→      } else {\\n138→        toast.error(result.error);\\n139→      }\\n140→    }\\n141→\\n142→    setSubmitting(false);\\n143→  }\\n144→\\n145→  async function handleDelete() {\\n146→    if (!deleteId) return;\\n147→    setDeleting(true);\\n148→\\n149→    const result = await deleteProduct(deleteId);\\n150→    if (!result.error) {\\n151→      toast.success(\\\"Produk berhasil dihapus\\\");\\n152→      loadData();\\n153→      setDeleteId(null);\\n154→    } else {\\n155→      toast.error(result.error);\\n156→    }\\n157→\\n158→    setDeleting(false);\\n159→  }\\n160→\\n161→  function formatPrice(price: number) {\\n162→    return new Intl.NumberFormat(\\\"id-ID\\\", {\\n163→      style: \\\"currency\\\",\\n164→      currency: \\\"IDR\\\",\\n165→      minimumFractionDigits: 0,\\n166→    }).format(price);\\n167→  }\\n168→\\n169→  const filteredProducts = products.filter((p) => {\\n170→    const matchSearch = p.name.toLowerCase().includes(search.toLowerCase());\\n171→    const matchCategory = !filterCategory || p.categoryId === filterCategory;\\n172→    const matchStatus =\\n173→      !filterStatus ||\\n174→      (filterStatus === \\\"active\\\" && p.isActive) ||\\n175→      (filterStatus === \\\"inactive\\\" && !p.isActive) ||\\n176→      (filterStatus === \\\"outofstock\\\" && p.stock === 0);\\n177→    return matchSearch && matchCategory && matchStatus;\\n178→  });\\n179→\\n180→  return (\\n181→    <div className=\\\"space-y-3\\\">\\n182→      {/* Header */}\\n183→      <div className=\\\"flex items-center justify-between\\\">\\n184→        <div className=\\\"flex items-center gap-2.5\\\">\\n185→          <div className=\\\"flex h-8 w-8 items-center justify-center rounded-lg bg-zinc-900\\\">\\n186→            <Package className=\\\"h-4 w-4 text-white\\\" />\\n187→          </div>\\n188→          <div>\\n189→            <h1 className=\\\"text-base font-semibold leading-tight\\\">Kelola Produk</h1>\\n190→            <p className=\\\"text-xs text-zinc-500\\\">Tambah, edit, dan hapus produk toko</p>\\n191→          </div>\\n192→        </div>\\n193→        <Button size=\\\"sm\\\" className=\\\"h-8 gap-1.5 bg-zinc-900 text-xs\\\" onClick={openCreateModal}>\\n194→          <Plus className=\\\"h-3.5 w-3.5\\\" /> Tambah\\n195→        </Button>\\n196→      </div>\\n197→\\n198→      {/* Search & Filters */}\\n199→      <div className=\\\"flex items-center gap-2\\\">\\n200→        <div className=\\\"relative flex-1\\\">\\n201→          <Search className=\\\"absolute left-2.5 top-1/2 h-4 w-4 -translate-y-1/2 text-zinc-400\\\" />\\n202→          <input\\n203→            type=\\\"text\\\"\\n204→            placeholder=\\\"Cari produk...\\\"\\n205→            value={search}\\n206→            onChange={(e) => setSearch(e.target.value)}\\n207→            className=\\\"h-8 w-full rounded-lg border border-zinc-200 bg-white pl-8 pr-3 text-sm placeholder:text-zinc-400 focus:border-zinc-900 focus:outline-none focus:ring-1 focus:ring-zinc-900\\\"\\n208→          />\\n209→        </div>\\n210→        <select\\n211→          value={filterCategory}\\n212→          onChange={(e) => setFilterCategory(e.target.value)}\\n213→          className=\\\"h-8 rounded-lg border border-zinc-200 bg-white px-2 text-xs focus:border-zinc-900 focus:outline-none\\\"\\n214→        >\\n215→          <option value=\\\"\\\">Kategori</option>\\n216→          {categories.map((cat) => (\\n217→            <option key={cat.id} value={cat.id}>{cat.name}</option>\\n218→          ))}\\n219→        </select>\\n220→        <select\\n221→          value={filterStatus}\\n222→          onChange={(e) => setFilterStatus(e.target.value)}\\n223→          className=\\\"h-8 rounded-lg border border-zinc-200 bg-white px-2 text-xs focus:border-zinc-900 focus:outline-none\\\"\\n224→        >\\n225→          <option value=\\\"\\\">Status</option>\\n226→          <option value=\\\"active\\\">Aktif</option>\\n227→          <option value=\\\"inactive\\\">Nonaktif</option>\\n228→          <option value=\\\"outofstock\\\">Habis</option>\\n229→        </select>\\n230→      </div>\\n231→\\n232→      {/* Table */}\\n233→      {loading ? (\\n234→        <div className=\\\"flex items-center justify-center py-12\\\">\\n235→          <Loader2 className=\\\"h-5 w-5 animate-spin text-zinc-400\\\" />\\n236→        </div>\\n237→      ) : filteredProducts.length === 0 ? (\\n238→        <div className=\\\"flex flex-col items-center justify-center rounded-lg border border-zinc-200 bg-white py-10\\\">\\n239→          <Package className=\\\"h-8 w-8 text-zinc-300\\\" />\\n240→          <p className=\\\"mt-2 text-sm font-medium text-zinc-900\\\">Tidak ada produk</p>\\n241→          <p className=\\\"mt-0.5 text-xs text-zinc-500\\\">\\n242→            {search || filterCategory || filterStatus ? \\\"Coba ubah filter\\\" : \\\"Tambahkan produk pertama\\\"}\\n243→          </p>\\n244→        </div>\\n245→      ) : (\\n246→        <div className=\\\"rounded-lg border border-zinc-200 bg-white\\\">\\n247→          <div className=\\\"overflow-x-auto\\\">\\n248→          <table className=\\\"w-full text-sm\\\">\\n249→            <thead>\\n250→              <tr className=\\\"border-b border-zinc-100 bg-zinc-50/80\\\">\\n251→                <th className=\\\"px-3 py-2 text-left text-xs font-medium text-zinc-500\\\">Produk</th>\\n252→                <th className=\\\"px-3 py-2 text-left text-xs font-medium text-zinc-500\\\">Kategori</th>\\n253→                <th className=\\\"px-3 py-2 text-left text-xs font-medium text-zinc-500\\\">Harga</th>\\n254→                <th className=\\\"px-3 py-2 text-left text-xs font-medium text-zinc-500\\\">Stok</th>\\n255→                <th className=\\\"px-3 py-2 text-left text-xs font-medium text-zinc-500\\\">Status</th>\\n256→                <th className=\\\"px-3 py-2 text-right text-xs font-medium text-zinc-500\\\">Aksi</th>\\n257→              </tr>\\n258→            </thead>\\n259→            <tbody className=\\\"divide-y divide-zinc-100\\\">\\n260→              {filteredProducts.map((product) => (\\n261→                <tr key={product.id} className=\\\"hover:bg-zinc-50/50\\\">\\n262→                  <td className=\\\"px-3 py-2\\\">\\n263→                    <div className=\\\"flex items-center gap-2.5\\\">\\n264→                      <div className=\\\"h-9 w-9 flex-shrink-0 overflow-hidden rounded-md bg-zinc-100\\\">\\n265→                        {product.thumbnail ? (\\n266→                          <img src={product.thumbnail} alt=\\\"\\\" className=\\\"h-full w-full object-cover\\\" />\\n267→                        ) : (\\n268→                          <div className=\\\"flex h-full w-full items-center justify-center\\\">\\n269→                            <ImageIcon className=\\\"h-4 w-4 text-zinc-400\\\" />\\n270→                          </div>\\n271→                        )}\\n272→                      </div>\\n273→                      <div className=\\\"min-w-0\\\">\\n274→                        <p className=\\\"font-medium text-zinc-900 truncate text-sm\\\">{product.name}</p>\\n275→                        <p className=\\\"text-xs text-zinc-500 truncate max-w-[180px]\\\">\\n276→                          {product.description || \\\"—\\\"}\\n277→                        </p>\\n278→                      </div>\\n279→                    </div>\\n280→                  </td>\\n281→                  <td className=\\\"px-3 py-2\\\">\\n282→                    <span className=\\\"rounded bg-zinc-100 px-1.5 py-0.5 text-xs text-zinc-600\\\">\\n283→                      {product.category?.name || \\\"—\\\"}\\n284→                    </span>\\n285→                  </td>\\n286→                  <td className=\\\"px-3 py-2 font-medium text-zinc-900\\\">{formatPrice(product.price)}</td>\\n287→                  <td className=\\\"px-3 py-2\\\">\\n288→                    <span className={product.stock === 0 ? \\\"text-red-600 font-medium\\\" : \\\"text-zinc-600\\\"}>\\n289→                      {product.stock}\\n290→                    </span>\\n291→                  </td>\\n292→                  <td className=\\\"px-3 py-2\\\">\\n293→                    <span className={`rounded-full px-2 py-0.5 text-[10px] font-medium ${\\n294→                      product.isActive ? \\\"bg-green-50 text-green-700\\\" : \\\"bg-red-50 text-red-700\\\"\\n295→                    }`}>\\n296→                      {product.isActive ? \\\"Aktif\\\" : \\\"Nonaktif\\\"}\\n297→                    </span>\\n298→                  </td>\\n299→                  <td className=\\\"px-3 py-2\\\">\\n300→                    <div className=\\\"flex justify-end gap-1\\\">\\n301→                      <button\\n302→                        onClick={() => openEditModal(product)}\\n303→                        className=\\\"rounded p-1 text-zinc-400 hover:bg-zinc-100 hover:text-zinc-600\\\"\\n304→                        title=\\\"Edit\\\"\\n305→                      >\\n306→                        <Pencil className=\\\"h-3.5 w-3.5\\\" />\\n307→                      </button>\\n308→                      <button\\n309→                        onClick={() => setDeleteId(product.id)}\\n310→                        className=\\\"rounded p-1 text-zinc-400 hover:bg-red-50 hover:text-red-600\\\"\\n311→                        title=\\\"Hapus\\\"\\n312→                      >\\n313→                        <Trash2 className=\\\"h-3.5 w-3.5\\\" />\\n314→                      </button>\\n315→                    </div>\\n316→                  </td>\\n317→                </tr>\\n318→              ))}\\n319→            </tbody>\\n320→          </table>\\n321→          </div>\\n322→        </div>\\n323→      )}\\n324→\\n325→      {/* Create/Edit Modal */}\\n326→      {showModal && (\\n327→        <div className=\\\"fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4\\\">\\n328→          <div className=\\\"w-full max-w-md max-h-[85vh] overflow-y-auto rounded-xl bg-white\\\">\\n329→            <div className=\\\"sticky top-0 flex items-center justify-between border-b border-zinc-100 bg-white px-4 py-3\\\">\\n330→              <h2 className=\\\"text-sm font-semibold\\\">\\n331→                {editingProduct ? \\\"Edit Produk\\\" : \\\"Tambah Produk\\\"}\\n332→              </h2>\\n333→              <button onClick={() => setShowModal(false)} className=\\\"rounded p-1 hover:bg-zinc-100\\\">\\n334→                <X className=\\\"h-4 w-4\\\" />\\n335→              </button>\\n336→            </div>\\n337→\\n338→            <form onSubmit={handleSubmit} className=\\\"p-4 space-y-4\\\">\\n339→              {/* Thumbnail */}\\n340→              <div>\\n341→                <label className=\\\"mb-1.5 block text-xs font-medium\\\">Thumbnail</label>\\n342→                <div\\n343→                  onClick={() => fileInputRef.current?.click()}\\n344→                  className=\\\"relative flex h-32 cursor-pointer items-center justify-center overflow-hidden rounded-lg border-2 border-dashed border-zinc-200 bg-zinc-50 hover:border-zinc-300\\\"\\n345→                >\\n346→                  {thumbnailPreview ? (\\n347→                    <img src={thumbnailPreview} alt=\\\"Preview\\\" className=\\\"h-full w-full object-contain\\\" />\\n348→                  ) : (\\n349→                    <div className=\\\"text-center\\\">\\n350→                      <Upload className=\\\"mx-auto h-6 w-6 text-zinc-400\\\" />\\n351→                      <p className=\\\"mt-1 text-xs text-zinc-500\\\">Klik untuk upload</p>\\n352→                    </div>\\n353→                  )}\\n354→                </div>\\n355→                <input ref={fileInputRef} type=\\\"file\\\" accept=\\\"image/*\\\" onChange={handleFileChange} className=\\\"hidden\\\" />\\n356→              </div>\\n357→\\n358→              {/* Name */}\\n359→              <div>\\n360→                <label className=\\\"mb-1.5 block text-xs font-medium\\\">Nama Produk</label>\\n361→                <input\\n362→                  type=\\\"text\\\"\\n363→                  required\\n364→                  value={formData.name}\\n365→                  onChange={(e) => setFormData({ ...formData, name: e.target.value })}\\n366→                  className=\\\"h-9 w-full rounded-lg border border-zinc-200 px-3 text-sm focus:border-zinc-900 focus:outline-none focus:ring-1 focus:ring-zinc-900\\\"\\n367→                />\\n368→              </div>\\n369→\\n370→              {/* Description */}\\n371→              <div>\\n372→                <label className=\\\"mb-1.5 block text-xs font-medium\\\">Deskripsi</label>\\n373→                <textarea\\n374→                  value={formData.description}\\n375→                  onChange={(e) => setFormData({ ...formData, description: e.target.value })}\\n376→                  rows={2}\\n377→                  className=\\\"w-full rounded-lg border border-zinc-200 px-3 py-2 text-sm focus:border-zinc-900 focus:outline-none focus:ring-1 focus:ring-zinc-900\\\"\\n378→                />\\n379→              </div>\\n380→\\n381→              {/* Price & Stock */}\\n382→              <div className=\\\"grid grid-cols-2 gap-3\\\">\\n383→                <div>\\n384→                  <label className=\\\"mb-1.5 block text-xs font-medium\\\">Harga (Rp)</label>\\n385→                  <input\\n386→                    type=\\\"number\\\"\\n387→                    required\\n388→                    min=\\\"0\\\"\\n389→                    value={formData.price}\\n390→                    onChange={(e) => setFormData({ ...formData, price: e.target.value })}\\n391→                    className=\\\"h-9 w-full rounded-lg border border-zinc-200 px-3 text-sm focus:border-zinc-900 focus:outline-none focus:ring-1 focus:ring-zinc-900\\\"\\n392→                  />\\n393→                </div>\\n394→                <div>\\n395→                  <label className=\\\"mb-1.5 block text-xs font-medium\\\">Stok</label>\\n396→                  <input\\n397→                    type=\\\"number\\\"\\n398→                    min=\\\"0\\\"\\n399→                    value={formData.stock}\\n400→                    onChange={(e) => setFormData({ ...formData, stock: e.target.value })}\\n401→                    className=\\\"h-9 w-full rounded-lg border border-zinc-200 px-3 text-sm focus:border-zinc-900 focus:outline-none focus:ring-1 focus:ring-zinc-900\\\"\\n402→                  />\\n403→                </div>\\n404→              </div>\\n405→\\n406→              {/* Category */}\\n407→              <div>\\n408→                <label className=\\\"mb-1.5 block text-xs font-medium\\\">Kategori</label>\\n409→                <select\\n410→                  required\\n411→                  value={formData.categoryId}\\n412→                  onChange={(e) => setFormData({ ...formData, categoryId: e.target.value })}\\n413→                  className=\\\"h-9 w-full rounded-lg border border-zinc-200 px-3 text-sm focus:border-zinc-900 focus:outline-none focus:ring-1 focus:ring-zinc-900\\\"\\n414→                >\\n415→                  <option value=\\\"\\\">Pilih Kategori</option>\\n416→                  {categories.map((cat) => (\\n417→                    <option key={cat.id} value={cat.id}>{cat.name}</option>\\n418→                  ))}\\n419→                </select>\\n420→              </div>\\n421→\\n422→              {/* Status */}\\n423→              <div className=\\\"flex items-center justify-between rounded-lg border border-zinc-200 px-3 py-2.5\\\">\\n424→                <span className=\\\"text-xs font-medium\\\">Produk Aktif</span>\\n425→                <label className=\\\"relative inline-flex cursor-pointer items-center\\\">\\n426→                  <input\\n427→                    type=\\\"checkbox\\\"\\n428→                    checked={formData.isActive}\\n429→                    onChange={(e) => setFormData({ ...formData, isActive: e.target.checked })}\\n430→                    className=\\\"peer sr-only\\\"\\n431→                  />\\n432→                  <div className=\\\"peer h-5 w-9 rounded-full bg-zinc-200 after:absolute after:left-[2px] after:top-[2px] after:h-4 after:w-4 after:rounded-full after:bg-white after:transition-all peer-checked:bg-zinc-900 peer-checked:after:translate-x-full\\\"></div>\\n433→                </label>\\n434→              </div>\\n435→\\n436→              {/* Actions */}\\n437→              <div className=\\\"flex gap-2 pt-2\\\">\\n438→                <Button type=\\\"button\\\" variant=\\\"outline\\\" className=\\\"flex-1 h-9 text-xs\\\" onClick={() => setShowModal(false)}>\\n439→                  Batal\\n440→                </Button>\\n441→                <Button type=\\\"submit\\\" className=\\\"flex-1 h-9 bg-zinc-900 text-xs\\\" disabled={submitting}>\\n442→                  {submitting ? <Loader2 className=\\\"h-4 w-4 animate-spin\\\" /> : \\\"Simpan\\\"}\\n443→                </Button>\\n444→              </div>\\n445→            </form>\\n446→          </div>\\n447→        </div>\\n448→      )}\\n449→\\n450→      {/* Delete Modal */}\\n451→      {deleteId && (\\n452→        <div className=\\\"fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4\\\">\\n453→          <div className=\\\"w-full max-w-xs rounded-xl bg-white p-4\\\">\\n454→            <div className=\\\"flex h-10 w-10 items-center justify-center rounded-full bg-red-100\\\">\\n455→              <Trash2 className=\\\"h-5 w-5 text-red-600\\\" />\\n456→            </div>\\n457→            <h2 className=\\\"mt-3 text-sm font-semibold\\\">Hapus Produk?</h2>\\n458→            <p className=\\\"mt-1 text-xs text-zinc-500\\\">Produk yang dihapus tidak dapat dikembalikan.</p>\\n459→            <div className=\\\"mt-4 flex gap-2\\\">\\n460→              <Button variant=\\\"outline\\\" className=\\\"flex-1 h-8 text-xs\\\" onClick={() => setDeleteId(null)}>\\n461→                Batal\\n462→              </Button>\\n463→              <Button className=\\\"flex-1 h-8 bg-red-600 hover:bg-red-700 text-xs\\\" onClick={handleDelete} disabled={deleting}>\\n464→                {deleting ? <Loader2 className=\\\"h-4 w-4 animate-spin\\\" /> : \\\"Hapus\\\"}\\n465→              </Button>\\n466→            </div>\\n467→          </div>\\n468→        </div>\\n469→      )}\\n470→    </div>\\n471→  );\\n472→}\\n473→\",\n  \"time\": \"2026-04-17 02:28:37 PM UTC+0000\"\n}"
            }
