          "group_id": null,
          "role": "approval",
          "content": [
            {
              "type": "reasoning",
              "is_native": true,
              "reasoning": "The user wants me to:\n1. Fix the thumbnail not rendering on the Kelola Produk page\n2. Restyle the page to be more professional and modern\n3. Add icon to the header\n4. Make the searchbar full width\n5. General improvements to make it look better\n\nLet me rewrite the Kelola Produk page with these improvements.",
              "signature": ""
